<mvc:View
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    controllerName="gmrproject.controller.output"
    height="100%"
    xmlns:plugins="sap.m.plugins"
    xmlns:columnmenu="sap.m.table.columnmenu"
    xmlns:sap.ui.fl="sap.ui.fl"
    xmlns:sap.ui.dt="sap.ui.dt"
    xmlns:vm="sap.ui.fl.variants"
    xmlns:dnd="sap.ui.core.dnd"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
>
    <VBox class="outputCenterPage leftPanel">
        <!-- HEADER -->
        <HBox
            justifyContent="SpaceBetween"
            alignItems="Center"
        >
            <VBox>
                <Title text="Output Center" />
                <Text text="Browse annexure output" />
            </VBox>
            <Button
                text="Create Export"
                press="onCreateExport"
            />
        </HBox>

        <!-- LIST -->
        <List items="{/annexures}">
            <items>
                <CustomListItem
                    type="Active"
                    press="onRowPress"
                >
                    <VBox class="outputRowCard">
                        <!-- SUMMARY -->
                        <HBox class="outputRowSummary">
                            <Text text="{tag}" />
                            <Text
                                text="{annexure}"
                                width="40%"
                            />
                            <Text
                                text="{formId}"
                                width="15%"
                            />
                            <Text
                                text="{source}"
                                width="20%"
                            />
                            <Text
                                text="{pages}"
                                width="5%"
                            />
                            <ObjectStatus text="{status}" />

                            <core:Icon
                                src="{= ${expanded} ? 'sap-icon://navigation-down-arrow' : 'sap-icon://navigation-right-arrow' }"
                            />
                        </HBox>

                        <!-- DETAIL PANEL -->
                        <VBox
                            visible="{expanded}"
                            class="outputRowDetailPanel"
                        >
                            <!-- <Text text="{description}" />

                            <HBox>
                                <Text text="{contentLayout}" />
                                <Text text="{dataSource}" />
                                <Text text="{date}" />
                            </HBox> -->

                            <VBox class="sapUiSmallMargin">
                                <!-- What's inside -->
                                <Text
                                    text="What's inside"
                                    class="labelSmall"
                                />

                                <!-- Main Title -->
                                <Title
                                    text="Coal source-wise consumption with weighted GCV and landed cost build-up — feeds ECR."
                                    level="H4"
                                    wrapping="true"
                                />

                                <!-- Content layout -->
                                <VBox class="sectionMargin">
                                    <Text
                                        text="Content layout"
                                        class="labelSmall"
                                    />
                                    <FormattedText
                                        htmlText="Page 1: source breakdown table · Page 2: GCV variance · Page 3: discount certificate (Shakti)"
                                    />
                                </VBox>

                                <!-- Data source & mapping -->
                                <VBox class="sectionMargin">
                                    <Text
                                        text="Data source &amp; mapping"
                                        class="labelSmall"
                                    />
                                    <Text
                                        text="SourceSD-023 Form-15 Coal · Routine 938 (landed price)"
                                    />
                                    <Text text="GeneratorZSD_ANX_A3_GEN" />
                                </VBox>

                                <!-- Seal & integrity -->
                                <VBox class="sectionMargin">
                                    <Text
                                        text="Seal &amp; integrity"
                                        class="labelSmall"
                                    />
                                    <Text text="SHA-256e1f4…a07c" />
                                    <Text text="DSCe-Mudra Class-3" />
                                    <Text text="Stamped12-Jan-2026 09:15 IST" />
                                </VBox>

                                <!-- Footer label -->
                                <VBox class="sectionMargin">
                                    <Text
                                        text="Fields rendered on this annexure"
                                        class="labelSmall"
                                    />
                                </VBox>
                            </VBox>

                            <VBox width="50%">
                                <Table items="{data}">
                                    <columns>
                                        <Column>
                                            <Text text="Field" />
                                        </Column>
                                        <Column>
                                            <Text text="Type" />
                                        </Column>
                                        <Column>
                                            <Text text="Description" />
                                        </Column>
                                    </columns>

                                    <items>
                                        <ColumnListItem>
                                            <cells>
                                                <Text text="{field}" />
                                                <Text text="{type}" />
                                                <Text
                                                    text="{path:'description', formatter:'.formatDescription'}"
                                                />
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>

                            <HBox>
                                <Button
                                    text="Preview PDF"
                                    press="onPreviewPdf"
                                />
                                <Button
                                    text="Download"
                                    press="onDownload"
                                />
                                <Button
                                    text="Trace"
                                    press="onViewTrace"
                                />
                            </HBox>
                        </VBox>
                    </VBox>
                </CustomListItem>
            </items>
        </List>
    </VBox>
</mvc:View>
