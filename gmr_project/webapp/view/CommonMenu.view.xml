<mvc:View
    controllerName="gmrproject.controller.CommonMenu"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <!-- ✅ MAIN BAR -->
    <HBox
        class="menuBar"
        justifyContent="SpaceBetween"
    >
        <!-- ✅ LEFT MENU (ROW FIX) -->
        <HBox class="menuLeft">
            <!-- ITEM 1 -->
            <HBox
                id="menuContainer12"
                items="{
        path: 'menu>/menuItems',
        filters: [
            { path: 'isMainMenu', operator: 'EQ', value1: true }
        ]
    }"
            >
                <HBox
                    class="menuItem"
                    visible="true"
                >
                    <customData>
                        <core:CustomData
                            key="active"
                            value="{menu>active}"
                        />
                    </customData>

                    <customData>
                        <core:CustomData
                            key="id"
                            value="{menu>id}"
                        />
                    </customData>

                    <customData>
                        <core:CustomData
                            key="route"
                            value="{menu>route}"
                        />
                    </customData>

                    <Text
                        text="{menu>icon}"
                        class="iconCircle"
                        visible="{= ${menu>icon} !== '' }"
                    />

                    <!-- <Text
                        text="{menu>badge}"
                        class="badge"
                        visible="{= ${menu>badge} !== '' }"
                    /> -->

                    <VBox>
                        <Text
                            text="{menu>title}"
                            class="title"
                        />
                        <Text
                            text="{menu>subText}"
                            class="subText"
                        />
                    </VBox>
                </HBox>
            </HBox>

            <!-- ITEM 5 -->
            <HBox
                id="appsItem"
                class="menuItem"
            >
                <customData>
                    <core:CustomData
                        key="route"
                        value="more"
                    />
                </customData>
                <Text
                    id="plusIconBtn"
                    text="+"
                    tooltip="More Apps"
                    class="plusIcon"
                />

                <!-- <VBox> -->
                <!-- <Text
                        text="More Apps"
                        class="title"
                    /> -->
                <!-- <Text
                        text="8 supporting apps"
                        class="subText"
                    /> -->
                <!-- </VBox> -->
            </HBox>
        </HBox>

        <!-- ✅ RIGHT SIDE -->
        <!-- <HBox class="menuRight">
            <Text
                text="PPA GRIDCO"
                class="tag"
            />
            <Text
                text="FY 2025-26"
                class="tag"
            />
        </HBox> -->
    </HBox>

    <Dialog
        id="myDialog"
        draggable="true"
        resizable="true"
        contentWidth="100%"
        contentHeight="99%"
    >
        <content>
               <VBox  width="100%">
                <core:Fragment
                    fragmentName="gmrproject.view.OtherMenu"
                    type="XML"
                />
                
            <VBox id="viewContainer" width="100%" />

            </VBox>
        </content>

        <endButton>
            <Button
                text="Close"
                press="onCloseDialog"
            />
        </endButton>
    </Dialog>
</mvc:View>
