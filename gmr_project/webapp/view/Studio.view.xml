<mvc:View
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    controllerName="gmrproject.controller.Studio"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
>

<FlexBox
    direction="{= ${device>/system/phone} ? 'Column' : 'Row' }">

    <HBox width="100%">
        <!-- ✅ LEFT PANEL -->
        <VBox
            width="25%"
            class="leftPanel"
        >
            <!-- HEADER -->
            <HBox
                justifyContent="SpaceBetween"
                class="panelHeader"
            >
                <Text
                    text="PPA Context"
                    class="sectionTitle"
                />
                <Text
                    text="5"
                    class="countBadge"
                />
            </HBox>

            <VBox>
                <VBox items="{tileModel>/items}">
                    <items>
                        <CustomListItem
                            type="Active"
                            class="noBorderItem"
                            press="onItemPress"
                        >
                            <HBox
                                class="contextItem"
                                justifyContent="SpaceBetween"
                            >
                                <!-- LEFT -->
                                <HBox
                                    alignItems="Center"
                                    class="leftContent"
                                >
                                    <!-- Circle -->
                                    <Text
                                        text="{tileModel>code}"
                                        class="circle"
                                    />

                                    <!-- Text -->
                                    <VBox>
                                        <Text
                                            text="{tileModel>name}"
                                            class="title"
                                        />
                                        <Text
                                            text="{tileModel>location}"
                                            class="subText"
                                        />
                                    </VBox>
                                </HBox>

                                <!-- RIGHT -->
                                <VBox alignItems="End">
                                    <Text
                                        text="{tileModel>section}"
                                        class="tag green"
                                    />

                                    <Text
                                        text="{tileModel>count}"
                                        class="progress"
                                    />
                                </VBox>
                            </HBox>
                        </CustomListItem>
                    </items>
                </VBox>
            </VBox>
        </VBox>

        <!-- ✅ RIGHT PANEL -->
        <VBox
            width="75%"
            class="rightPanel"
        >
            <!-- HEADER CARD -->
            <HBox
                class="headerCard"
                justifyContent="SpaceBetween"
            >
                <VBox class="mainContainer">
                    <!-- HEADER -->
                    <HBox
                        class="headerBar"
                        justifyContent="SpaceBetween"
                        alignItems="Center"
                    >
                        <HBox
                            alignItems="Center"
                            class="headerLeft"
                        >
                            <VBox
                                class="logoBox "
                                justifyContent="Center"
                                alignItems="Center"
                            >
                                <Text
                                    text="GR"
                                    id="code"
                                    class="logo-text"
                                />
                            </VBox>

                            <VBox class="headerTitles">
                                <Title
                                    class="header-text"
                                    id="title"
                                    text="GRIDCO — Configuration Studio"
                                />
                                <Text
                                    class="studio-hero"
                                    id="subtitle"
                                    text="Kamalanga · GKEL · Section 62 · Pricing Proc: ZKELGR"
                                />
                            </VBox>
                        </HBox>

                        <HBox
                            class="headerRight"
                            alignItems="Center"
                            justifyContent="End"
                        >
                            <VBox class="infoItem">
                                <Text
                                    text="SECTION"
                                    class="label right-side-text"
                                />
                                <Text
                                    text="S62"
                                    id="section"
                                    class="value right-side-value"
                                />
                            </VBox>

                            <VBox class="infoItem">
                                <Text
                                    text="PLANT"
                                    class="label right-side-text"
                                />
                                <Text
                                    text="Kamalanga"
                                    id="plant"
                                    class="value right-side-value"
                                />
                            </VBox>

                            <VBox class="infoItem">
                                <Text
                                    text="ACTIVE"
                                    class="label right-side-text"
                                />
                                <Text
                                    text="10/15"
                                    id="active"
                                    class="valueGreen"
                                />
                            </VBox>

                            <VBox class="infoItem">
                                <Text
                                    text="SAVED"
                                    class="label right-side-text"
                                />
                                <Text
                                    text="0/8"
                                    id="saved"
                                    class="valueYellow"
                                />
                            </VBox>
                        </HBox>
                    </HBox>
                </VBox>
            </HBox>
            <HBox
                class="headerCard"
                justifyContent="SpaceBetween"
            >
                <VBox class="pageWrapper">
                    <!-- HEADER -->
                    <HBox
                        class="boardHeader"
                        alignItems="Center"
                    >
                        <core:Icon
                            src="sap-icon://grid"
                            size="1.2rem"
                            class="boardIcon"
                        />

                        <Title
                            text="Configuration Tile Board"
                            class="boardTitle"
                        />

                        <Text
                            text="15 features · 4 groups"
                            class="pillGrey"
                        />
                    </HBox>

                    <!-- SECTION -->
                    <HBox class="sectionHeader">
                        <Title
                            text="DATA UPLOAD"
                            class="sectionTitle"
                        />
                        <Text
                            text="4 features"
                            class="pillLight"
                        />
                    </HBox>

                    <!-- GRID -->
                    <FlexBox
                        id="dataUploadFlexboxid"
                        wrap="Wrap"
                        class="tileGrid"
                        items="{
        path: 'fileUpload>/tiles'
    }"
                    >
                        <items >
                        
                            <VBox class="tile success" >
                                <!-- Header -->
                                <HBox justifyContent="SpaceBetween">
                                    <Text
                                        id="iconText"
                                        text="{fileUpload>icon/text}"
                                    />

                                    <Text
                                        text="{= ${fileUpload>state} === 'ready' ? '✓Saved' : 'Sub-config required' }"
                                        class="{= ${fileUpload>state} === 'ready' ? 'badgeSuccess' : 'badgeWarning' }"
                                    />
                                </HBox>

                                <!-- Title -->
                                <Title
                                    text="{fileUpload>name}"
                                    class="tileTitle"
                                />

                                <!-- Description -->
                                <Text
                                    text="{fileUpload>description}"
                                    class="tileDesc"
                                    wrapping="true"
                                />

                                <!-- Chips -->
                                <HBox items="{fileUpload>badges}">
                                    <items>
                                        <Text
                                            text="{fileUpload>.}"
                                            class="{
                            = ${fileUpload>.} === 'popup needed'
                            ? 'chipWarning'
                            : 'chip'
                        }"
                                        />
                                    </items>
                                </HBox>
                            </VBox>
                        </items>
                    </FlexBox>

                    <HBox class="sectionHeader">
                        <Title
                            text="Calculation"
                            class="sectionTitle"
                        />
                        <Text
                            text="3 features"
                            class="pillLight"
                        />
                    </HBox>
                    <FlexBox
                        id="CalculationFlexboxid"
                        wrap="Wrap"
                        class="tileGrid"
                        items="{
        path: 'calculation>/tiles'
    }"
                    >
                        <items>
                            <VBox class="tile success">
                                <!-- Header -->
                                <HBox justifyContent="SpaceBetween">
                                    <Text
                                        id="iconCalculationText"
                                        text="{calculation>icon/text}"
                                    />

                                    <Text
                                        text="{= ${calculation>state} === 'ready' ? '✓Saved' : 'Sub-config required' }"
                                        class="{= ${calculation>state} === 'ready' ? 'badgeSuccess' : 'badgeWarning' }"
                                    />
                                </HBox>

                                <!-- Title -->
                                <Title
                                    text="{calculation>name}"
                                    class="tileTitle"
                                />

                                <!-- Description -->
                                <Text
                                    text="{calculation>description}"
                                    class="tileDesc"
                                    wrapping="true"
                                />

                                <!-- Chips -->
                                <HBox items="{calculation>badges}">
                                    <items>
                                        <Text
                                            text="{calculation>.}"
                                            class="{
                            = ${calculation>.} === 'popup needed'
                            ? 'chipWarning'
                            : 'chip'
                        }"
                                        />
                                    </items>
                                </HBox>
                            </VBox>
                        </items>
                    </FlexBox>

                    <HBox class="sectionHeader">
                        <Title
                            text="Master Inputs"
                            class="sectionTitle"
                        />
                        <Text
                            text="1 features"
                            class="pillLight"
                        />
                    </HBox>
                    <FlexBox
                        id="MasterInputsFlexboxid"
                        wrap="Wrap"
                        class="tileGrid"
                        items="{
        path: 'masterInput>/tiles'
    }"
                    >
                        <items>
                            <VBox class="tile success">
                                <!-- Header -->
                                <HBox justifyContent="SpaceBetween">
                                    <Text
                                        id="iconMasterInputsText"
                                        text="{masterInput>icon/text}"
                                    />

                                    <Text
                                        text="{= ${masterInput>state} === 'ready' ? '✓Saved' : 'Sub-config required' }"
                                        class="{= ${masterInput>state} === 'ready' ? 'badgeSuccess' : 'badgeWarning' }"
                                    />
                                </HBox>

                                <!-- Title -->
                                <Title
                                    text="{masterInput>name}"
                                    class="tileTitle"
                                />

                                <!-- Description -->
                                <Text
                                    text="{masterInput>description}"
                                    class="tileDesc"
                                    wrapping="true"
                                />

                                <!-- Chips -->
                                <HBox items="{masterInput>badges}">
                                    <items>
                                        <Text
                                            text="{masterInput>.}"
                                            class="{
                            = ${masterInput>.} === 'popup needed'
                            ? 'chipWarning'
                            : 'chip'
                        }"
                                        />
                                    </items>
                                </HBox>
                            </VBox>
                        </items>
                    </FlexBox>

                    <HBox class="sectionHeader">
                        <Title
                            text="Rates"
                            class="sectionTitle"
                        />
                        <Text
                            text="0 features"
                            class="pillLight"
                        />
                    </HBox>
                    <FlexBox
                        id="ratesFlexboxid"
                        wrap="Wrap"
                        class="tileGrid"
                        items="{
        path: 'rates>/tiles'
    }"
                    >
                        <items>
                            <VBox class="tile success">
                                <!-- Header -->
                                <HBox justifyContent="SpaceBetween">
                                    <Text
                                        id="iconratesText"
                                        text="{rates>icon/text}"
                                    />

                                    <Text
                                        text="{= ${rates>state} === 'ready' ? '✓Saved' : 'Sub-config required' }"
                                        class="{= ${rates>state} === 'ready' ? 'badgeSuccess' : 'badgeWarning' }"
                                    />
                                </HBox>

                                <!-- Title -->
                                <Title
                                    text="{rates>name}"
                                    class="tileTitle"
                                />

                                <!-- Description -->
                                <Text
                                    text="{rates>description}"
                                    class="tileDesc"
                                    wrapping="true"
                                />

                                <!-- Chips -->
                                <HBox items="{rates>badges}">
                                    <items>
                                        <Text
                                            text="{rates>.}"
                                            class="{
                            = ${rates>.} === 'popup needed'
                            ? 'chipWarning'
                            : 'chip'
                        }"
                                        />
                                    </items>
                                </HBox>
                            </VBox>
                        </items>
                    </FlexBox>

                    <HBox class="sectionHeader">
                        <Title
                            text="Output"
                            class="sectionTitle"
                        />
                        <Text
                            text="2 features"
                            class="pillLight"
                        />
                    </HBox>
                   <FlexBox
                        id="OutputFlexboxid"
                        wrap="Wrap"
                        class="tileGrid"
                        items="{
        path: 'output>/tiles'
    }"
                    >
                        <items>
                            <VBox class="tile success">
                                <!-- Header -->
                                <HBox justifyContent="SpaceBetween">
                                    <Text
                                        id="iconOutputText"
                                        text="{output>icon/text}"
                                    />

                                    <Text
                                        text="{= ${output>state} === 'ready' ? '✓Saved' : 'Sub-config required' }"
                                        class="{= ${output>state} === 'ready' ? 'badgeSuccess' : 'badgeWarning' }"
                                    />
                                </HBox>

                                <!-- Title -->
                                <Title
                                    text="{output>name}"
                                    class="tileTitle"
                                />

                                <!-- Description -->
                                <Text
                                    text="{output>description}"
                                    class="tileDesc"
                                    wrapping="true"
                                />

                                <!-- Chips -->
                                <HBox items="{output>badges}">
                                    <items>
                                        <Text
                                            text="{output>.}"
                                            class="{
                            = ${output>.} === 'popup needed'
                            ? 'chipWarning'
                            : 'chip'
                        }"
                                        />
                                    </items>
                                </HBox>
                            </VBox>
                        </items>
                    </FlexBox>
                </VBox>
            </HBox>
        </VBox>
    </HBox>


</FlexBox>

</mvc:View>
