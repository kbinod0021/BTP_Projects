                        <Input id="idNumber" value="" placeholder="Enter a number with country code"/>
                        <Input id="idText" value="" placeholder="Enter a text to send"/>
                        <Image width="20%" src="./images/whatsapp.png" press="handleWhatsAppPress"/>
                </HBox> -->
</mvc:View>
