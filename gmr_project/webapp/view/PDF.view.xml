<mvc:View
    controllerName="gmrproject.controller.PDF"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>


  <VBox width="100%" class="sapUiContentPadding">
    
    <!-- ✅ HEADER -->
    <Toolbar class="headerBar">
        <Title text="Form 15 Coal - File Upload"/>
        <ToolbarSpacer/>
    </Toolbar>

    <!-- ✅ UPLOAD SECTION -->
    <VBox class="uploadSection">
        <VBox class="uploadBox">
            <VBox alignItems="Center" class="uploadContent">
                <core:Icon src="sap-icon://upload-to-cloud" size="3rem" class="uploadIconiles here or click to browse"/>
                <Text text="Supported formats: CSV, PDF, XLSX" class="uploadHint"/>
                <u:FileUploader
                    id="fileUploader"
                    uploadUrl="/"
                    multiple="true"
                    fileType="csv,pdf,xlsx"
                    maximumFileSize="50"
                    change="onFileSelected"
                    class="uploadButton"/>
            </VBox>
        </VBox>
    </VBox>


    <!-- ✅ UPLOADED FILES LIST -->
   <VBox
    
    class="uploadedFilesSection">

        <Title level="H5" text="Uploaded Files" class="uploadedFilesTitle"/>
        
        <List
    id="filesList"
    items="{/uploadedFiles}"
    class="filesList">

    <items>
        <CustomListItem>
            <HBox width="100%" alignItems="Center" class="fileItem">
                <VBox width="100%">
                    <HBox alignItems="Center">
                    <Title level="H6" text="{fileName}" class="fileName"/>
                        <ObjectStatus
                            icon="{path: 'fileType', formatter: '.formatFileIcon'}"
                            state="{path: 'status', formatter: '.formatStatusState'}"/>
                    </HBox>

                    <HBox>
                        <Text text="{path: 'fileSize', formatter: '.formatFileSize'}"/>
                        <Text text=" | "/>
                        <Text text="{uploadDate}"/>
                    </HBox>
                </VBox>

                <HBox justifyContent="End">
                    <Button text="Preview" press="onPreviewFile"/>
                    <Button icon="sap-icon://delete" press="onDeleteFile"/>
                </HBox>
            </HBox>
        </CustomListItem>
    </items>

</List>

    </VBox>

    <!-- ✅ ACTION BUTTONS -->
    <Toolbar class="actionBar">
        <ToolbarSpacer/>
        <Button text="Clear All" press="onClearAll" visible="{path: '/uploadedFiles', formatter: '.formatFilesVisible'}"/>
        <Button text="Submit Files" type="Emphasized" press="onSubmitFiles" visible="{path: '/uploadedFiles', formatter: '.formatFilesVisible'}"/>
    </Toolbar>

    <!-- ✅ EMPTY STATE -->
    <VBox 
        alignItems="Center" 
        justifyContent="Center" 
        visible="{path: '/uploadedFiles', formatter: '.formatFilesEmpty'}"
        class="emptyState">
        <core:Icon src="sap-icon://document" size="4rem" color="#CCC" class="emptyyStateText"/>
    </VBox>

</VBox>

<!-- Preview Dialog -->
<Dialog id="previewDialog" title="File Preview" stretchOnPhone="true">
    <VBox id="previewContainer" width="100%">
        <core:HTML id="previewHtml" />
    </VBox>
    <Button text="Close" press="onClosePreview" type="Transparent"/>
</Dialog>



</mvc:View>