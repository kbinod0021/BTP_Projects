<mvc:View
    controllerName="gmrproject.controller.smartTable"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
>
    <VBox
        width="100%"
        class="sapUiContentPadding"
    >
        <!-- <smartFilterBar:SmartFilterBar
    id="smartFilterBar"
    entitySet="YourEntitySet"
    enableBasicSearch="true"
    persistencyKey="SmartFilter"
    search="onSearch" /> -->

        <smartFilterBar:SmartFilterBar
            id="smartFilterBar"
            entitySet="YourEntitySet"
            persistencyKey="SmartFilter_Explored"
            search="onSearch"
        >
            <smartFilterBar:controlConfiguration>
                <smartFilterBar:ControlConfiguration
                    key="ID"
                    visibleInAdvancedArea="true"
                />

                <smartFilterBar:ControlConfiguration
                    key="Name"
                    visibleInAdvancedArea="true"
                />

                <smartFilterBar:ControlConfiguration
                    key="City"
                    visibleInAdvancedArea="true"
                />
            </smartFilterBar:controlConfiguration>
        </smartFilterBar:SmartFilterBar>

        <smartTable:SmartTable
            id="smartTable"
            entitySet="YourEntitySet"
            smartFilterId="smartFilterBar"
            enableAutoBinding="true"
            tableType="Table"
            useExportToExcel="true"
            useVariantManagement="true"
            header="Smart Table Example"
            showRowCount="true"
            initiallyVisibleFields="ID,Name,City"
        >
            <Table
                id="idTable"
                mode="MultiSelect"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <ToolbarSpacer />
                        <Button
                            class="sapUISmallMarginBeginEnd"
                            type="Success"
                            icon="sap-icon://add"
                            text="Add"
                            press="onAdd"
                        />
                         <Button
                            class="sapUISmallMarginBeginEnd"
                            type="Emphasized"
                            icon="sap-icon://edit"
                            text="Edit"
                            press="onEdit"
                        />
                         <Button
                            class="sapUISmallMarginBeginEnd"
                            type="Reject"
                            icon="sap-icon://delete"
                            text="Delete"
                            press="onDelete"
                        />
                    </OverflowToolbar>
                </headerToolbar>
            </Table>
        </smartTable:SmartTable>
    </VBox>
</mvc:View>
