<mvc:View
    controllerName="gmrproject.controller.PlanningCalendar"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified">

    <VBox class="sapUiSmallMargin">

        <!-- Toolbar -->
        <OverflowToolbar>
            <Button text="Today" press="onToday"/>

            <ToolbarSpacer/>

            <Button text="Add Appointment" press="onOpenDialog"/>
        </OverflowToolbar>

        <!-- Planning Calendar -->
     <PlanningCalendar
    id="PC1"
    startDate="{/startDate}"
    rows="{/people}"
    viewKey="WorkWeek"
    appointmentsVisualization="Filled"
    showWeekNumbers="true"
    class="customCalendar">

    <views>

        <!-- Day -->
        <PlanningCalendarView
            key="Day"
            intervalType="Day"
            description="Day"
            intervalsS="1"
            intervalsM="1"
            intervalsL="1" />

        <!-- Work Week -->
        <PlanningCalendarView
            key="WorkWeek"
            intervalType="Day"
            description="Work Week"
            intervalsS="5"
            intervalsM="5"
            intervalsL="5" />

        <!-- Full Week -->
        <PlanningCalendarView
            key="Week"
            intervalType="Day"
            description="Week"
            intervalsS="7"
            intervalsM="7"
            intervalsL="7" />

        <!-- Month -->
        <PlanningCalendarView
            key="Month"
            intervalType="Month"
            description="Month"
            intervalsS="1"
            intervalsM="1"
            intervalsL="1" />

    </views>

    <rows>

        <PlanningCalendarRow
            title="{name}"
            appointments="{appointments}">

            <appointments>

                <unified:CalendarAppointment
                    startDate="{start}"
                    endDate="{end}"
                    title="{title}"
                    text="{info}"
                    type="{type}" />

            </appointments>

        </PlanningCalendarRow>

    </rows>

</PlanningCalendar>

    </VBox>

</mvc:View>