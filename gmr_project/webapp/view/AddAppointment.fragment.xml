<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog title="Add Appointment">

    <VBox class="sapUiSmallMargin">

      <DatePicker id="dlgDate" />

      <TimePicker id="dlgStartTime" />

      <TimePicker id="dlgEndTime" />

      <Input id="dlgDesc" placeholder="Enter Description" />

    </VBox>

    <beginButton>
      <Button text="Add" press="onSaveAppointment" />
    </beginButton>

    <endButton>
      <Button text="Cancel" press="onCloseDialog" />
    </endButton>

  </Dialog>
</core:FragmentDefinition>