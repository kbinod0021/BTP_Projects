<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="addAppointmentDialog"
        title="Add Appointment"
        contentWidth="420px"
       
class="myDialog"
>

        <content>

            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                width="100%"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                labelSpanS="12"
                columnsXL="1"
                columnsL="1"
                columnsM="1">

                <!-- Date -->
                <Label text="Date" required="true"/>

                <DatePicker
                    id="dlgDate"
                    width="100%"
                    placeholder="Select Date" />

                <!-- Start Time -->
                <Label text="Start Time" required="true"/>

                <TimePicker
                    id="dlgStartTime"
                    width="100%"
                    displayFormat="HH:mm"
                    valueFormat="HH:mm"
                    placeholder="Select Start Time" />

                <!-- End Time -->
                <Label text="End Time" required="true"/>

                <TimePicker
                    id="dlgEndTime"
                    width="100%"
                    displayFormat="HH:mm"
                    valueFormat="HH:mm"
                    placeholder="Select End Time" />

                <!-- Description -->
                <Label text="Description"/>

                <TextArea
                    id="dlgDesc"
                    rows="4"
                    width="100%"
                    placeholder="Enter Description" />

            </f:SimpleForm>

        </content>

        <beginButton>
            <Button
                text="Add"
                type="Emphasized"
                icon="sap-icon://add"
                press="onSaveAppointment" />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                icon="sap-icon://decline"
                press="onCloseDialog" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>