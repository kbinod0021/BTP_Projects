<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="addAppointmentDialog"
        title="Add Appointment"
        contentWidth="420px"
       
class="myDialog"
>

        <content>

          <f:SimpleForm
    editable="true"
    layout="ResponsiveGridLayout"
    width="100%"
    labelSpanXL="3"
    labelSpanL="3"
    labelSpanM="3"
    labelSpanS="12"
    columnsXL="1"
    columnsL="1"
    columnsM="1">

    <!-- Start -->
    <Label text="Start" required="true" />
    <HBox width="100%">
        <DatePicker
            id="dlgStartDate"
           width="95%"
            placeholder="Select Start Date"
            class="sapUiTinyMarginEnd" />

        <TimePicker
            id="dlgStartTime"
            width="95%"
            displayFormat="HH:mm"
            valueFormat="HH:mm"
            placeholder="Select Start Time" />
    </HBox>

    <!-- End -->
    <Label text="End" required="true" />
    <HBox width="100%">
        <DatePicker
            id="dlgEndDate"
            width="95%"
            placeholder="Select End Date"
            class="sapUiTinyMarginEnd" />

        <TimePicker
            id="dlgEndTime"
            width="95%"
            displayFormat="HH:mm"
            valueFormat="HH:mm"
            placeholder="Select End Time" />
    </HBox>

    <!-- Description -->
    <Label text="Description" />
    <TextArea
        id="dlgDesc"
        rows="4"
        width="100%"
        placeholder="Enter Description" />

</f:SimpleForm>

        </content>

        <beginButton>
            <Button
                text="Add"
                type="Emphasized"
                icon="sap-icon://add"
                press="onSaveAppointment" />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                icon="sap-icon://decline"
                press="onCloseDialog" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>