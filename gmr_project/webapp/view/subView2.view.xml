<mvc:View
    controllerName="gmrproject.controller.subView2"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:table="sap.ui.table"
    displayBlock="true"
    	xmlns:l="sap.ui.layout"
>
    <HBox>
        <VBox>
            <table:Table
                id="customerTable"
                rows="{customerModel>/customers}"
                width="100%"
            >
                <table:columns>
                    <table:Column>
                        <Label text="Name" />
                        <table:template>
                            <Text text="{customerModel>name}" />
                        </table:template>
                    </table:Column>

                    <table:Column>
                        <Label text="Address" />
                        <table:template>
                            <Text text="{customerModel>address}" />
                        </table:template>
                    </table:Column>

                    <table:Column>
                        <Label text="Email" />
                        <table:template>
                            <Text text="{customerModel>email}" />
                        </table:template>
                    </table:Column>
                </table:columns>
            </table:Table>

            <VBox
                alignItems="Start"
                class="customBtn"
            >
                <Button
                    text="Create"
                    width="120px"
                    press="onOpenDialog"
                    class="sapUiSmallMarginBottom"
                />

                <Button
                    text="Edit"
                    width="120px"
                    press="onEdit"
                    class="sapUiSmallMarginBottom"
                />

                <Button
                    text="Delete"
                    width="120px"
                    press="onDelete"
                    class="sapUiSmallMarginBottom"
                />

                <Button
                    text="Help"
                    width="120px"
                    press="onHelpPress"
                    class=""
                />
            </VBox>
        </VBox>
    </HBox>
