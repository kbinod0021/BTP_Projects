<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="1.0"
    xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx">

    <edmx:DataServices
        xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata"
        m:DataServiceVersion="2.0">

        <Schema Namespace="YourNamespace"
            xmlns="http://schemas.microsoft.com/ado/2008/09/edm"
            xmlns:ui="com.sap.vocabularies.UI.v1"
            xmlns:sap="http://www.sap.com/Protocols/SAPData">  <!-- ✅ IMPORTANT -->

            <!-- Entity Type -->
            <EntityType Name="YourEntityType">
                <Key>
                    <PropertyRef Name="ID"/>
                </Key>

                <!-- ✅ Make all fields filterable -->
                <Property Name="ID"   Type="Edm.String" Nullable="false" sap:filterable="true"/>
                <Property Name="Name" Type="Edm.String" sap:filterable="true"/>
                <Property Name="City" Type="Edm.String" sap:filterable="true"/>
                <Property Name="Age"  Type="Edm.String" sap:filterable="true"/>

            </EntityType>

            <!-- ✅ Annotations -->
            <Annotations Target="YourNamespace.YourEntityType">

                <!-- Table Columns -->
                <Annotation Term="UI.LineItem">
                    <Collection>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="ID"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="Name"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="City"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="Age"/>
                        </Record>
                    </Collection>
                </Annotation>

                <!-- ✅ Filters -->
                <Annotation Term="UI.SelectionFields">
                    <Collection>
                        <PropertyPath>ID</PropertyPath>
                        <PropertyPath>Name</PropertyPath>
                        <PropertyPath>City</PropertyPath>
                        <PropertyPath>Age</PropertyPath>
                    </Collection>
                </Annotation>

            </Annotations>

            <!-- Container -->
            <EntityContainer Name="Container" m:IsDefaultEntityContainer="true">
                <EntitySet Name="YourEntitySet"
                           EntityType="YourNamespace.YourEntityType"/>
            </EntityContainer>

        </Schema>
    </edmx:DataServices>
</edmx:Edmx>