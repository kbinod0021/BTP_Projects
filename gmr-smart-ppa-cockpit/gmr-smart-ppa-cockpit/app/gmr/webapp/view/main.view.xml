<mvc:View
    controllerName="gmr.controller.main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page
        showHeader="false"
        xmlns="sap.m"
        xmlns:mvc="sap.ui.core.mvc"
    >
        <content>
            <!-- <HBox> -->
            <VBox class="customHeader">
                <HBox
                    justifyContent="SpaceBetween"
                    alignItems="Center"
                    width="100%"
                >
                    <!-- LEFT -->
                    <HBox
                        alignItems="Center"
                        class="leftSection"
                    >
                        <!-- <Avatar initials="GMR" class="logoCircle"/> -->

                        <Image
                            src="images/gmr.jpg"
                            class="logoCircle"
                        />

                        <VBox>
                            <Text
                                text="SD‑PPA Cockpit"
                                class="mainTitle"
                            />
                            <Text
                                text="S/4HANA 2023 PCE · FPS03 · V8"
                                class="subTitle"
                            />
                        </VBox>
                    </HBox>

                    <HBox
                        alignItems="Center"
                        class="rightSection"
                    >
                        <HBox class="notifWrapper">
                            <Button
                                icon="sap-icon://bell"
                                class="iconBtn"
                            />
                            <Text
                                text="3"
                                class="notifBadge"
                            />
                        </HBox>

                        <Button
                            icon="sap-icon://sys-help"
                            class="iconBtn"
                        />
                        <Button
                            icon="sap-icon://history"
                            class="iconBtn"
                        />

                        <Avatar
                            initials="AK"
                            class="avatar"
                        />
                    </HBox>
                </HBox>
            </VBox>

            <VBox>
                <VBox id="menuContainer">
                    <core:Fragment
                        fragmentName="gmr.fragment.commonMenu"
                        type="XML"
                    />
                </VBox>
                <VBox width="100%">
                    <App id="innerApp" />
                </VBox>
            </VBox>
            <!-- </HBox> -->
        </content>
    </Page>
</mvc:View>
