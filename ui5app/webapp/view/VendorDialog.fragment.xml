    <HBox class="sapUiSmallMarginBottom" justifyContent="SpaceBetween">

    <VBox width="48%">
        <Label text="Country Auto Select" required="true"/>
        <Input
            id="countryInput"
            showSuggestion="true"
            suggest="onSuggest"
            suggestionItemSelected="onCountrySelected"
            required="true"
            suggestionItems="{
                path: '/countries',
                templateShareable: false
            }">
            <suggestionItems>
                <core:Item key="{code}" text="{name}" />
            </suggestionItems>
        </Input>
    </VBox>

    <VBox width="48%">
        <Label text="Country" required="true"/>
        <ComboBox width="100%"
            id="countryCombo"
            selectedKey="{/selectedCountry}"
            selectionChange="onCountryChange"
            items="{ path: '/countries', templateShareable: false }"
            required="true">
            <items>
                <core:Item key="{code}" text="{name}" />
            </items>
        </ComboBox>
    </VBox>

</HBox>

