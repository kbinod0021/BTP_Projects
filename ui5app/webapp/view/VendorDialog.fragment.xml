    <core:FragmentDefinition
     controllerName="ui5app.controller.VendorDialog"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="vendorDialog"
        title="Vendor Information"
        stretchOnPhone="true"
        draggable="true"
        resizable="true"
        contentWidth="450px">

        <content>
            <VBox class="sapUiMediumMargin">

                <Label text="Vendor ID" required="true"/>
                <Input placeholder="Enter Vendor ID"/>

                <Label text="Vendor Name" required="true"
                       class="sapUiSmallMarginTop"/>
                <Input placeholder="Enter Vendor Name"/>

                <Label text="Email"
                       class="sapUiSmallMarginTop"/>
                <Input type="Email"
                       placeholder="vendor@email.com"/>

                <Label text="Phone Number"
                       class="sapUiSmallMarginTop"/>
                <Input type="Tel"
                       placeholder="+91 XXXXX XXXXX"/>

                <Label text="City"
                       class="sapUiSmallMarginTop"/>
                <Input placeholder="City"/>

            </VBox>
        </content>

        <beginButton>
            <Button
                text="Save"
                type="Emphasized"
                press="onVendorSave"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press="onVendorClose"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>