<HBox class="sapUiSmallMarginBottom" justifyContent="SpaceBetween">

    <VBox width="48%">
        <Label text="State" required="true"/>
        <ComboBox
            id="stateCombo" width="100%"
            enabled="{/stateEnabled}"
            selectedKey="{/selectedState}"
            selectionChange="onStateChange"
            required="true"
            items="{ path: '/filteredStates', templateShareable: false }">
            <items>
                <core:Item key="{code}" text="{name}" />
            </items>
        </ComboBox>
    </VBox>

    <VBox width="48%">
        <Label text="City" required="true"/>
        <ComboBox width="100%"
            id="cityCombo"
            enabled="{/cityEnabled}"
            required="true"
            items="{ path: '/filteredCities', templateShareable: false }">
            <items>
                <core:Item key="{code}" text="{name}" />
            </items>
        </ComboBox>
    </VBox>

</HBox>


                
