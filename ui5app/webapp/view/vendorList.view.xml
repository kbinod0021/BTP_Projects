                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="pcLine"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                       
                        <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="Seq No" />

                                        <core:Icon
                                            src="{= ${view>/sortState/seqNo} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/seqNo} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="seqNo"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                       

                        <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="PC Type" />

                                        <core:Icon
                                            src="{= ${view>/sortState/pcType} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/pcType} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="pcType"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>


                       

                         <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="PART Number" />

                                        <core:Icon
                                            src="{= ${view>/sortState/partNumber} === 'asc' ? 'sap-icon://sort-ascending' :
