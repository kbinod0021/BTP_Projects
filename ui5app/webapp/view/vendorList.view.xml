<mvc:View
    controllerName="ui5app.controller.vendorList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
>
    <Page
        title="Vendor List"
        showNavButton="true"
        navButtonPress="onNavBack"
    >
        <content>
            <!-- ✅ Move IconTabBar here -->
            <VBox class="mainContainer">
                <!-- HEADER ROW -->
                <HBox
                    alignItems="Center"
                    justifyContent="SpaceBetween"
                    width="100%"
                >
                    <!-- LEFT: TITLE + TABS -->
                    <HBox alignItems="Center">
                        <Title
                            text="Pending PC"
                            level="H2"
                            class="titleMargin"
                        />

                        <IconTabBar
                            selectedKey="{view>/selectedBU}"
                            select="onBUChange"
                            items="{view>/businessDivision}"
                            class="customTabBar"
                            expandable="false"
                        >
                            <items>
                                <IconTabFilter
                                    key="{view>key}"
                                    text="{view>text}"
                                />
                            </items>
                        </IconTabBar>
                    </HBox>

                    <!-- RIGHT: FILTERS + ACTIONS -->
                    <HBox
                        alignItems="Center"
                        class="filterBar"
                    >
                        <Input
                            width="12rem"
                            placeholder="Supplier Name"
                            class="roundedInput"
                        />

                        <ComboBox
                            width="12rem"
                            placeholder="Supplier Location"
                            class="roundedInput"
                        />

                        <Input
                            width="14rem"
                            value="{filter>/partNumber}"
                            placeholder="Part number/Name"
                            class="roundedInput"
                        />

                        <Input
                            width="10rem"
                            value="{filter>/pcNo}"
                            placeholder="PC No"
                            class="roundedInput"
                        />

                        <!-- ACTION BUTTONS -->
                        <Button
                            icon="sap-icon://search"
                            class="actionBtn"
                        />
                        <Button
                            icon="sap-icon://refresh"
                            class="actionBtn"
                        />
                        <Button
                            icon="sap-icon://filter"
                            class="actionBtn"
                            press="onOpenDialog"
                        />
                        <Button
                            icon="sap-icon://download"
                            class="actionBtn"
                            press="onDownloadExcel"
                        />
                    </HBox>
                </HBox>
            </VBox>

            <!-- TABLE -->

            <Panel class="sapUiResponsiveMargin">
                <Table
                    id="myTable"
                    items="{table>/data}"
                    growing="true"
                    growingThreshold="20"
                    sticky="ColumnHeaders"
                >
                    <columns>
                        <!-- <Column>
                <header>
                    <Button text="HCIL Location" press="onSort">
                        <customData>
                            <core:CustomData key="field" value="hcilLocation"/>
                        </customData>
                    </Button>
                </header>
            </Column> -->
                        <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="HCIL Location" />

                                        <core:Icon
                                            src="{= ${view>/sortState/hcilLocation} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/hcilLocation} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="hcilLocation"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                       
                         <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="Delivery Date" />

                                        <core:Icon
                                           src="{= ${view>/sortState/deliveryDate} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/deliveryDate} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="deliveryDate"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                       
                         <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="PC No" />

                                        <core:Icon
                                             src="{= ${view>/sortState/pcNumber} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/pcNumber} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="pcNumber"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                      

                         <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="PC Line" />

                                        <core:Icon
                                           src="{= ${view>/sortState/pcLine} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/pcLine} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
