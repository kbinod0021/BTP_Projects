    <Dialog
        id="filterDialog"
        title="Filters"
        contentWidth="340px"
        draggable="false"
        resizable="false"
        class="rightEndDialog sapUiResponsivePadding"
    >
        <VBox
            class="filterContent"
            width="100%"
        >
            <Label text="Delivery Date Range" />
            <DateRangeSelection width="100%" />

            <Label text="HCIL Location" />
            <ComboBox width="100%" />

            <Label text="Part Number" />
            <Input width="100%" />

            <Label text="Part Color" />
            <Input width="100%" />
        </VBox>

        <footer>
            <Toolbar class="footerToolbar">
                <ToolbarSpacer />

                <Button
                    icon="sap-icon://search"
                    type="Emphasized"
                    press="onSearch"
                />
                <Button
                    icon="sap-icon://refresh"
                    type="Transparent"
                    press="onReset"
                />
                <Button
                    icon="sap-icon://decline"
                    type="Transparent"
                    press="onCloseDialog"
                />
                <Button
                    icon="sap-icon://download"
                    type="Transparent"
                    press="onDownload"
                />
            </Toolbar>
        </footer>
    </Dialog>
</mvc:View>
