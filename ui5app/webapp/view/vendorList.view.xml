                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="partNumber"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                      

 <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="PART Name" />

                                        <core:Icon
                                            src="{= ${view>/sortState/partName} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/partName} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="partName"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                     

 <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="Scheduled Qty" />

                                        <core:Icon
                                        src="{= ${view>/sortState/scheduledQty} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/scheduledQty} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="scheduledQty"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                       

<Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="Pending Qty" />

                                        <core:Icon
                                             src="{= ${view>/sortState/pendingQty} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/pendingQty} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="pendingQty"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                      
                        <Column>
                            <header>
                                <HBox alignItems="Center">
                                    <items>
                                        <Text text="Status" />

                                        <core:Icon
                                             src="{= ${view>/sortState/status} === 'asc' ? 'sap-icon://sort-ascending' :
                           ${view>/sortState/status} === 'desc' ? 'sap-icon://sort-descending' :
                           'sap-icon://sort' }"
                                            press="onSort"
                                            class="sapUiTinyMarginBegin"
                                        >
                                            <core:customData>
                                                <core:CustomData
                                                    key="field"
                                                    value="status"
                                                />
                                            </core:customData>
                                        </core:Icon>
                                    </items>
                                </HBox>
                            </header>
                        </Column>

                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{table>hcilLocation}" />
                                <Text text="{table>deliveryDate}" />
                                <Text text="{table>pcNumber}" />
                                <Text text="{table>pcLine}" />
                                <Text text="{table>seqNo}" />
                                <Text text="{table>pcType}" />
                                <Text text="{table>partNumber}" />
                                <Text text="{table>partName}" />
                                <Text text="{table>scheduledQty}" />
                                <Text text="{table>pendingQty}" />
                                <ObjectStatus
                                    text="{table>status}"
                                    state="{table>statusState}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
