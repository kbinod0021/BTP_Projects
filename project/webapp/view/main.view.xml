<mvc:View
    controllerName="project.controller.main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">

    <tnt:ToolPage id="toolPage">

        <!-- ✅ HEADER -->
        <tnt:header>
            <tnt:ToolHeader>
                <Button icon="sap-icon://menu2"
                        press=".onToggleMenu"/>
                <Title text="My Application" />
            </tnt:ToolHeader>
        </tnt:header>

        <!-- ✅ SIDE NAVIGATION -->
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav">

                <tnt:NavigationList  itemSelect=".onMenuItemSelect">

                    <tnt:NavigationListItem text="Products" key="Products"
                        icon="sap-icon://product"
                        select=".onMenuSelect"/>

                    <tnt:NavigationListItem text="Orders" key="Orders"  
                        icon="sap-icon://sales-order"/>

                    <tnt:NavigationListItem text="Reports"  key="Reports"
                        icon="sap-icon://business-objects-experience"/>

                </tnt:NavigationList>

            </tnt:SideNavigation>
        </tnt:sideContent>

        <!-- ✅ MAIN CONTENT -->
        <tnt:mainContents>

            <Page class="sapUiContentPadding" showHeader="false">

                <content>

                    <!-- ✅ YOUR EXISTING TABLE -->
                    <Table
                        id="idProductsTable"
                        growing="true"
                        mode="SingleSelectLeft"
                        selectionChange=".onRowSelect"
                        items="{ path: '/' }">

                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text="Products" />
                                <ToolbarSpacer />
                                <Button id="editButton" text="Edit" press=".onEdit"/>
                                <Button id="saveButton" text="Save" press=".onSave" visible="false"/>
                                <Button id="cancelButton" text="Cancel" press=".onCancel" visible="false"/>
                            </OverflowToolbar>
                        </headerToolbar>

                        <columns>
                            <Column><Text text="Product"/></Column>
                            <Column><Text text="Quantity"/></Column>
                            <Column><Text text="Weight"/></Column>
                            <Column><Text text="Price"/></Column>
                        </columns>

                        <items>
                            <ColumnListItem>
                                <cells>
                                    <ObjectIdentifier title="{Name}" text="{ProductId}" />
                                    <ObjectNumber number="{Quantity}" unit="{UoM}" />
                                    <ObjectNumber number="{WeightMeasure}" unit="{WeightUnit}" />
                                    <ObjectNumber number="{Price}" unit="{CurrencyCode}" />
                                </cells>
                            </ColumnListItem>
                        </items>

                    </Table>

                </content>

            </Page>

        </tnt:mainContents>

    </tnt:ToolPage>
</mvc:View>
